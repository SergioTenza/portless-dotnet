{
  "name": "portless-vscode",
  "displayName": "Portless.NET",
  "description": "VS Code extension for Portless.NET reverse proxy - manage routes, monitor health, and control the proxy from your editor",
  "version": "0.1.0",
  "publisher": "sergiotenza",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:portless.config.yaml"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "portless-container",
          "title": "Portless.NET",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "portless-container": [
        {
          "id": "portless-routes",
          "name": "Proxy Routes"
        }
      ]
    },
    "commands": [
      {
        "command": "portless.startProxy",
        "title": "Portless: Start Proxy",
        "icon": "$(play)"
      },
      {
        "command": "portless.stopProxy",
        "title": "Portless: Stop Proxy",
        "icon": "$(stop)"
      },
      {
        "command": "portless.refreshRoutes",
        "title": "Portless: Refresh Routes",
        "icon": "$(refresh)"
      },
      {
        "command": "portless.openRoute",
        "title": "Portless: Open Route in Browser",
        "icon": "$(globe)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "portless.refreshRoutes",
          "when": "view == portless-routes",
          "group": "navigation"
        },
        {
          "command": "portless.startProxy",
          "when": "view == portless-routes",
          "group": "navigation"
        },
        {
          "command": "portless.stopProxy",
          "when": "view == portless-routes",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "portless.openRoute",
          "when": "view == portless-routes && viewItem == route",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "Portless.NET",
      "properties": {
        "portless.proxyPort": {
          "type": "number",
          "default": 1355,
          "description": "The port the Portless proxy is running on"
        }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "lint": "echo 'No linter configured'"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "esbuild": "^0.19.0"
  }
}
